# HyperCrystal Environment Variables Template
# Copy to .env and fill with your own secrets

DEBUG=False

# Generate these with `python -c "import secrets; print(secrets.token_urlsafe(32))"`
JWT_SECRET=
DASH_SECRET_KEY=
HYPERCRYSTAL_ADMIN_KEY=

# Database (SQLite default, or PostgreSQL)
DATABASE_URL=sqlite:///data/hypercrystal.db

# Optional: external services
# OPENAI_API_KEY=
# SLACK_WEBHOOK_URL=
